{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "lib": [
      "es2024"
    ],
    "module": "nodenext",
    "outDir": "./dist",
    "resolveJsonModule": false,
    "rootDir": "./src",
    "strict": true,
    "target": "es2024",
    "declaration": true,
    "moduleResolution": "nodenext",
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.mts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
